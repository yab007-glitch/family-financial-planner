PORT=4000
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
DB_PATH=./planner.db
NODE_ENV=development
CORS_ORIGIN=http://localhost:4000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# === Railway Deployment ===
# On Railway, set these variables in the dashboard:
#   NODE_ENV=production
#   JWT_SECRET=<generate strong secret>
#   DB_PATH=/app/data/planner.db   (mount a volume at /app/data)
#   CORS_ORIGIN=<your-railway-domain>
#   COOKIE_SECURE=true
# Railway provides PORT automatically — do not set it manually.
