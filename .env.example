# Family Financial Planner - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=4000
NODE_ENV=development

# Session Security
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-super-secure-random-secret-here-at-least-64-characters-long

# Database
DB_PATH=./planner.db

# Production Settings (uncomment for production)
# NODE_ENV=production
# PORT=3000
# SESSION_SECRET=your-production-secret-here-generate-with-crypto
